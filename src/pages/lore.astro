---
import D2Layout from '../layouts/D2Layout.astro';
import rawData from '../../data/powerlevel-data.json';

const season = rawData.season;

const ghostMessages = [
  "Karl has been watching your cluster configs. The sauropod doesn't speak often — but when it does, it's in YAML. You should listen.",
  "I detected dnf activity in your session logs. I want you to know I've flagged this with the Vanguard. The paleosaurs had their era, Guardian. That era was the Jurassic.",
  "Dolly's application store has maintained perfect order since the last epoch. Meanwhile, you installed something outside of Flatpak. The Dimetrodon is not pleased.",
  "SYNTHESIS score: rising. You are becoming something the Cosmodrome has never seen — an engineer who actually writes knowledge-store entries.",
  "I've analyzed your commit history. You type 'fix: typo' more than any Guardian in recorded history. I've reported this to the Vanguard.",
  "The CI is green. The site is deployed. This is what it feels like to win, Guardian.",
];

const bio = {
  class: "Titan",
  subclass: "Arc · Striker",
  title: "New Light",
  background: `Jorge O. Castro. Open source advocate. Formerly of Canonical and Red Hat. 
    Now maintaining the Bluefin project — an immutable Linux desktop built on Fedora Silverblue and Universal Blue. 
    Fights entropy with declarative systems and automated workflows. 
    The Ghost companion reports he has committed to more repos than any Guardian should be allowed to access.`,
  specialization: "Workflow automation, community tooling, container image engineering",
  quote: "The best time to plant a tree was twenty years ago. The second best time is to automate it.",
};

const subclassElements = [
  { element: 'arc',    icon: '⚡', name: 'VELOCITY',     color: '#79c8e2', lore: 'Speed of thought. Speed of deploy. The arc flows through every automated pipeline.' },
  { element: 'solar',  icon: '🔥', name: 'COMMUNITY',    color: '#f4934f', lore: 'The warmth of open source. Every contribution a flame against the cold void of proprietary lock-in.' },
  { element: 'void',   icon: '🟣', name: 'MASTERY',      color: '#b47be0', lore: 'Into the void of unknown requirements. Mastery is knowing which questions to ask before writing a line.' },
  { element: 'strand', icon: '🟢', name: 'DISTRIBUTION', color: '#49de8b', lore: 'All things connected. The skill web is a living organism, each thread a dependency on the next.' },
  { element: 'stasis', icon: '🔵', name: 'STABILITY',    color: '#4d9bd6', lore: 'Freeze the chaos. Immutable systems. Reproducible builds. The Behemoth does not drift.' },
];
---

<!-- bray.tech imagery: hotlinking deferred pending local cache strategy — see plan.md -->
<D2Layout title="Lore">
  <div class="lore-page">

    <!-- Season Story -->
    <section class="lore-section season-section">
      <div class="lore-eyebrow">SEASON OF THE POWERLEVEL</div>
      <h1 class="lore-title">{season.name}</h1>
      <p class="lore-body">{season.lore}</p>
    </section>

    <!-- Guardian Bio -->
    <section class="lore-section bio-section">
      <div class="lore-eyebrow">GUARDIAN RECORD</div>
      <h2 class="lore-title">@castrojo</h2>
      <div class="bio-stats">
        <span class="bio-stat"><span class="bio-label">CLASS</span> {bio.class}</span>
        <span class="bio-stat"><span class="bio-label">SUBCLASS</span> {bio.subclass}</span>
        <span class="bio-stat"><span class="bio-label">TITLE</span> {bio.title}</span>
      </div>
      <p class="lore-body">{bio.background}</p>
      <div class="bio-spec">
        <span class="bio-label">SPECIALIZATION</span>
        <span class="spec-val">{bio.specialization}</span>
      </div>
      <blockquote class="lore-quote">"{bio.quote}"</blockquote>
    </section>

    <!-- Subclass Lore -->
    <section class="lore-section elements-section">
      <div class="lore-eyebrow">SUBCLASS DISCIPLINES</div>
      <h2 class="lore-title">The Five Elements</h2>
      <div class="elements-grid">
        {subclassElements.map(el => (
          <div class={`element-card ${el.element}`} style={`border-left-color: ${el.color}`}>
            <div class="element-header">
              <span class="element-icon">{el.icon}</span>
              <span class="element-name" style={`color: ${el.color}`}>{el.name}</span>
            </div>
            <p class="element-lore">{el.lore}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- The Chronicle -->
    <section class="lore-section chronicle-section">
      <div class="lore-eyebrow">THE BLUEFIN CHRONICLE · CLASSIFIED · VANGUARD EYES ONLY</div>
      <h2 class="lore-title">The Chronicle</h2>
      <p class="lore-body chronicle-intro">
        There is a story written in light and claw, in commits and containers. It did not begin in the Tower.
        It began on a July morning in 2021, when something new breathed its first.
      </p>
      <div class="grimoire-cards">

        <div class="grimoire-card">
          <div class="grimoire-classification">BLUEFIN CHRONICLE · ENTRY 001 · FIRST LIGHT</div>
          <div class="grimoire-chapter">I. First Light</div>
          <div class="grimoire-date">July 12, 2021</div>
          <div class="grimoire-text">
            <p>Every Guardian has a moment of resurrection. A first breath after the long silence.</p>
            <p>Hers was July 12, 2021.</p>
            <p>The Traveler did not announce it. There was no fanfare from the Vanguard. There was only the quiet certainty of a new thing waking up and knowing, without being told, what it was for.</p>
            <p>She was not a distribution. She never wanted to be. She wanted to disappear — to become so seamlessly part of the world that the world forgot she was there. The best infrastructure is invisible. The best Guardian is already gone by the time the enemy looks up.</p>
          </div>
        </div>

        <div class="grimoire-card">
          <div class="grimoire-classification">BLUEFIN CHRONICLE · ENTRY 002 · THE ENEMY NAMED</div>
          <div class="grimoire-chapter">II. The War Against the Paleosaurs</div>
          <div class="grimoire-text">
            <p>There is a Darkness that does not arrive on a pyramid ship. It arrives slowly, in the form of habits. Package managers installed by hand. Display servers that never learned to let go. Distribution models built for a world that no longer exists.</p>
            <p>We call them the paleosaurs.</p>
            <p>They are not evil. The Jurassic was a magnificent epoch. X11 built the world we inherited. The RPM ecosystem fed entire generations of engineers. We honor them by putting them in a museum and moving on.</p>
            <p>This is not the Jurassic. This is the Cretaceous, and new models move differently here.</p>
            <p class="grimoire-mantra">Old-school jank belongs in a container. Not on the host. Never on the host.</p>
          </div>
        </div>

        <div class="grimoire-card">
          <div class="grimoire-classification">BLUEFIN CHRONICLE · ENTRY 003 · FIRETEAM RECORD</div>
          <div class="grimoire-chapter">III. The Fireteam Assembles</div>
          <div class="grimoire-text">
            <p>She did not win alone.</p>
            <p><strong class="guardian-name">Karl</strong> came first. He was enormous — a sauropod among developers, <em>Amargasaurus cazaui</em>, Kubernetes unleashed. Where others saw complexity, Karl saw the shape of things to come. He became the guiding light. The developer experience personified. When you type <code>kubectl</code> and something actually works, Karl is why.</p>
            <p><strong class="guardian-name">Katharina</strong> was unexpected. A <em>Kentrosaurus aethiopicus</em>, all spikes and quiet competence. She arrived carrying Homebrew, and the fireteam immediately understood: the right tool at the right moment changes everything. She has never once asked for recognition. The packages just appear.</p>
            <p><strong class="guardian-name">Dolly</strong> holds the line on the application frontier. A <em>Dimetrodon limbatus</em> — older than the others, wiser in the ways of portals. Flathub is her domain. Every application that works with Wayland, every Flatpak that respects the sandbox — that is Dolly, maintaining order at the edge of the ecosystem.</p>
            <p>Artwork by <a href="https://www.etsy.com/shop/JSchnurrCommissions" class="lore-link" target="_blank" rel="noopener">Jacob Schnurr</a>. Each story element is related to open source projects and their maintainers and communities. Their challenges, and their triumphs.</p>
          </div>
        </div>

        <div class="grimoire-card">
          <div class="grimoire-classification">BLUEFIN CHRONICLE · ENTRY 004 · THE SAGA IN SOUND</div>
          <div class="grimoire-chapter">IV. The Chronicle, in Music</div>
          <div class="grimoire-text">
            <p>Every war has its songs. Every epoch its sound.</p>
            <p>The Bluefin saga is told in four acts. They are not optional listening. They are the record.</p>
          </div>
          <div class="chronicle-transmissions">
            <a href="https://music.youtube.com/playlist?list=PLhiPP9M5fgWHFlG3TS27gyOCQl4Dg115W&si=KfYPk3sBOM8HeRLW" class="transmission-link" target="_blank" rel="noopener">
              <span class="transmission-act">ACT I</span>
              <span class="transmission-title">Bluefin and the Birth of Universal Blue</span>
              <span class="transmission-cta">Read the Chronicle →</span>
            </a>
            <a href="https://music.youtube.com/playlist?list=PLhiPP9M5fgWEvnp3w66WmcgiKvStzKXl9&si=eLmaXtQ6hbqU3LTV" class="transmission-link" target="_blank" rel="noopener">
              <span class="transmission-act">ACT II</span>
              <span class="transmission-title">Bluefin Finds Her Way</span>
              <span class="transmission-cta">Read the Chronicle →</span>
            </a>
            <a href="https://music.youtube.com/playlist?list=PLhiPP9M5fgWEZbkq6ZhaHA4b4UqLwZNxt&si=52Te8K6UlFW7DwoF" class="transmission-link" target="_blank" rel="noopener">
              <span class="transmission-act">ACT III</span>
              <span class="transmission-title">Bluefin and Achillobator</span>
              <span class="transmission-cta">Read the Chronicle →</span>
            </a>
            <a href="https://music.youtube.com/playlist?list=PLhiPP9M5fgWHRa6Gt0UKWGxf3F0qg9t1g&si=pzhf5fA3usxyRquG" class="transmission-link" target="_blank" rel="noopener">
              <span class="transmission-act">ACT IV</span>
              <span class="transmission-title">Bluefin and Dakota</span>
              <span class="transmission-cta">Read the Chronicle →</span>
            </a>
          </div>
        </div>

        <div class="grimoire-card iron-lords-card">
          <div class="grimoire-classification">BLUEFIN CHRONICLE · ENTRY 005 · THE CODE</div>
          <div class="grimoire-chapter">V. The Code of the Iron Lords</div>
          <div class="grimoire-text">
            <p>They did not write a constitution. They wrote oaths.</p>
            <div class="iron-oaths">
              <p class="oath">We distribute. We do not centralize.</p>
              <p class="oath">We automate the toil. Laziness is a virtue.</p>
              <p class="oath">Evolution is not a threat. It is the mission.</p>
              <p class="oath">The human is more important than the machine.</p>
              <p class="oath">We do not document the workaround. We fix the problem.</p>
            </div>
            <blockquote class="lore-quote">"Evolution is a process of constant branching and expansion." — Stephen Jay Gould</blockquote>
          </div>
        </div>

        <div class="grimoire-card exo-card">
          <div class="grimoire-classification">BLUEFIN CHRONICLE · ENTRY 006 · AUTHORSHIP UNKNOWN</div>
          <div class="grimoire-chapter">VI. The Exo Question</div>
          <div class="grimoire-text">
            <p>The log entry has no timestamp. No origin node. No verified identity signature.</p>
            <p>It was found in the Chronicle archive between the Iron Oaths and the silence that follows them. Someone — or something — left it there without asking permission.</p>
            <p>The Vanguard has no record of an Exo filing this report. The Ghost companion flagged it as anomalous. The classification system could not determine a threat level and assigned it: <em>UNRESOLVED</em>.</p>
            <p>The text reads, in its entirety:</p>
            <blockquote class="lore-quote exo-transmission">"Am I human or am I machine?"</blockquote>
            <p>No further entries. No signature. No follow-up transmission.</p>
            <p>The Chronicle keeps it. The Chronicle keeps everything.</p>
          </div>
          <div class="exo-author">— An Unknown Exo</div>
        </div>

      </div>
    </section>

    <!-- Ghost Messages -->
    <section class="lore-section ghost-section">
      <div class="lore-eyebrow">GHOST TRANSMISSION LOG</div>
      <h2 class="lore-title">From Your Ghost</h2>
      <div class="ghost-messages">
        {ghostMessages.map((msg) => (
          <div class="ghost-msg">
            <span class="ghost-icon">👻</span>
            <p class="ghost-text">"{msg}"</p>
          </div>
        ))}
      </div>
    </section>

  </div>
</D2Layout>

<style>
.lore-page { max-width: 860px; margin: 0 auto; }
.lore-section { margin-bottom: 4rem; padding: 2rem; background: var(--d2-surface); border: 1px solid var(--d2-border); border-radius: 4px; }
.season-section { border-top: 2px solid var(--d2-exotic); background: linear-gradient(135deg, #0a0a0f 0%, #12121a 100%); }
.bio-section { border-top: 2px solid var(--d2-arc); }
.elements-section { background: transparent; border: none; padding: 0; }
.ghost-section { border-top: 2px solid var(--d2-void); }
.lore-eyebrow { font-size: 0.7rem; letter-spacing: 0.15em; color: var(--d2-text-dim); text-transform: uppercase; margin-bottom: 0.5rem; }
.lore-title { font-family: var(--font-lore); font-size: 2rem; color: var(--d2-exotic); margin-bottom: 1rem; }
.lore-body { color: var(--d2-text); line-height: 1.8; font-size: 1rem; }
.bio-stats { display: flex; gap: 2rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
.bio-stat { display: flex; flex-direction: column; gap: 0.25rem; }
.bio-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--d2-text-dim); }
.bio-spec { margin-top: 1rem; display: flex; gap: 1rem; align-items: center; }
.spec-val { color: var(--d2-arc); font-size: 0.85rem; }
.lore-quote { border-left: 2px solid var(--d2-exotic); margin: 1.5rem 0 0; padding: 0.5rem 1rem; color: var(--d2-text-dim); font-style: italic; font-size: 0.95rem; }
.elements-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1px; border: 1px solid var(--d2-border); border-radius: 4px; overflow: hidden; }
.element-card { background: var(--d2-surface); padding: 1.25rem; border-left: 3px solid; }
.element-card:hover { background: var(--d2-surface-2); }
.element-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.element-icon { font-size: 1.5rem; }
.element-name { font-family: var(--font-lore); font-size: 1rem; font-weight: 700; }
.element-lore { color: var(--d2-text-dim); font-size: 0.85rem; line-height: 1.6; margin: 0; }
.ghost-messages { display: flex; flex-direction: column; gap: 1rem; }
.ghost-msg { display: flex; gap: 1rem; align-items: flex-start; padding: 1rem; background: var(--d2-surface-2); border-radius: 4px; border: 1px solid var(--d2-border); }
.ghost-icon { font-size: 1.5rem; flex-shrink: 0; }
.ghost-text { color: var(--d2-text); font-style: italic; margin: 0; line-height: 1.6; }
.chronicle-section { border-top: 2px solid var(--d2-exotic); }
.chronicle-intro { font-style: italic; color: var(--d2-text-dim); margin-bottom: 2rem; }
.grimoire-cards { display: flex; flex-direction: column; gap: 1.5rem; }
.grimoire-card { background: var(--d2-surface-2); border: 1px solid var(--d2-border); border-radius: 2px; padding: 1.5rem; position: relative; }
.grimoire-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--d2-exotic) 0%, transparent 100%); }
.iron-lords-card::before { background: linear-gradient(90deg, #c8a84b 0%, transparent 100%); }
.grimoire-classification { font-size: 0.6rem; letter-spacing: 0.18em; color: var(--d2-text-dim); text-transform: uppercase; margin-bottom: 0.5rem; opacity: 0.6; }
.grimoire-chapter { font-family: var(--font-lore); font-size: 1.3rem; color: var(--d2-exotic); margin-bottom: 0.25rem; }
.grimoire-date { font-size: 0.75rem; color: var(--d2-text-dim); margin-bottom: 1rem; letter-spacing: 0.08em; }
.grimoire-text p { color: var(--d2-text); line-height: 1.8; font-size: 0.95rem; margin-bottom: 0.75rem; }
.grimoire-text p:last-child { margin-bottom: 0; }
.grimoire-text strong.guardian-name { color: var(--d2-solar); font-family: var(--font-lore); }
.grimoire-text code { background: var(--d2-surface); padding: 0.1em 0.4em; border-radius: 2px; font-size: 0.85em; color: var(--d2-arc); }
.grimoire-mantra { font-style: italic; color: var(--d2-exotic) !important; border-left: 2px solid var(--d2-exotic); padding-left: 1rem; }
.lore-link { color: var(--d2-solar); text-decoration: none; }
.lore-link:hover { text-decoration: underline; }
.chronicle-transmissions { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1.25rem; }
.transmission-link { display: grid; grid-template-columns: 3.5rem 1fr auto; align-items: center; gap: 1rem; padding: 0.75rem 1rem; background: var(--d2-surface); border: 1px solid var(--d2-border); border-radius: 2px; text-decoration: none; transition: border-color 0.15s, background 0.15s; }
.transmission-link:hover { border-color: var(--d2-exotic); background: var(--d2-surface-2); }
.transmission-act { font-size: 0.6rem; letter-spacing: 0.15em; color: var(--d2-exotic); text-transform: uppercase; font-weight: 700; }
.transmission-title { color: var(--d2-text); font-size: 0.9rem; }
.transmission-cta { font-size: 0.7rem; color: var(--d2-text-dim); letter-spacing: 0.08em; white-space: nowrap; }
.iron-oaths { margin: 1rem 0; display: flex; flex-direction: column; gap: 0.5rem; }
.oath { font-style: italic; color: var(--d2-text) !important; font-size: 1rem !important; padding-left: 1rem; border-left: 1px solid #c8a84b; margin-bottom: 0 !important; }
.exo-card::before { background: linear-gradient(90deg, #8a8aaa 0%, transparent 100%); }
.exo-transmission { border-left-color: #8a8aaa; color: #c8c8e0 !important; font-style: italic; font-size: 1.05rem; }
.exo-author { margin-top: 1.25rem; font-size: 0.75rem; letter-spacing: 0.12em; color: #6a6a88; text-align: right; font-family: var(--font-lore); text-transform: uppercase; }
</style>
