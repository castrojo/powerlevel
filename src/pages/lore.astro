---
import D2Layout from '../layouts/D2Layout.astro';
import rawData from '../../data/powerlevel-data.json';
import loreData from '../../data/lore-books.json';

const season = rawData.season;
const sessionCount = (rawData.stats?.endurance?.raw as number) ?? 0;
const books = loreData.books;

// Resolve unlock state at build time
const resolvedBooks = books.map(book => {
  const chapters = book.chapters.map(ch => {
    const bySessions = ch.unlock_after_sessions === null || sessionCount >= ch.unlock_after_sessions;
    const isUnlocked = ch.unlocked && bySessions;
    return { ...ch, isUnlocked };
  });
  return { ...book, chapters, unlockedCount: chapters.filter(c => c.isUnlocked).length };
});

// Lore stream: 3 most recently unlocked chapters (highest session threshold first)
const streamEntries = resolvedBooks
  .flatMap(book => book.chapters
    .filter(ch => ch.isUnlocked)
    .map(ch => ({ book, chapter: ch, threshold: ch.unlock_after_sessions ?? 0 }))
  )
  .sort((a, b) => b.threshold - a.threshold)
  .slice(0, 3);

const ghostMessages = [
  "Karl has been watching your cluster configs. The sauropod doesn't speak often — but when it does, it's in YAML. You should listen.",
  "I detected dnf activity in your session logs. I want you to know I've flagged this with the Vanguard. The paleosaurs had their era, Guardian. That era was the Jurassic.",
  "Dolly's application store has maintained perfect order since the last epoch. Meanwhile, you installed something outside of Flatpak. The Dimetrodon is not pleased.",
  "SYNTHESIS score: rising. You are becoming something the Cosmodrome has never seen — an engineer who actually writes knowledge-store entries.",
  "I've analyzed your commit history. You type 'fix: typo' more than any Guardian in recorded history. I've reported this to the Vanguard.",
  "The CI is green. The site is deployed. This is what it feels like to win, Guardian.",
];

const bio = {
  class: "Titan",
  subclass: "Arc · Striker",
  title: "New Light",
  background: `Jorge O. Castro. Open source advocate. Formerly of Canonical and Red Hat. 
    Now maintaining the Bluefin project — an immutable Linux desktop built on Fedora Silverblue and Universal Blue. 
    Fights entropy with declarative systems and automated workflows. 
    The Ghost companion reports he has committed to more repos than any Guardian should be allowed to access.`,
  specialization: "Workflow automation, community tooling, container image engineering",
  quote: "The best time to plant a tree was twenty years ago. The second best time is to automate it.",
};

const subclassElements = [
  { element: 'arc',    icon: '⚡', name: 'VELOCITY',     color: '#79c8e2', lore: 'Speed of thought. Speed of deploy. The arc flows through every automated pipeline.' },
  { element: 'solar',  icon: '🔥', name: 'COMMUNITY',    color: '#f4934f', lore: 'The warmth of open source. Every contribution a flame against the cold void of proprietary lock-in.' },
  { element: 'void',   icon: '🟣', name: 'MASTERY',      color: '#b47be0', lore: 'Into the void of unknown requirements. Mastery is knowing which questions to ask before writing a line.' },
  { element: 'strand', icon: '🟢', name: 'DISTRIBUTION', color: '#49de8b', lore: 'All things connected. The skill web is a living organism, each thread a dependency on the next.' },
  { element: 'stasis', icon: '🔵', name: 'STABILITY',    color: '#4d9bd6', lore: 'Freeze the chaos. Immutable systems. Reproducible builds. The Behemoth does not drift.' },
];
---

<!-- bray.tech imagery: hotlinking deferred pending local cache strategy — see plan.md -->
<D2Layout title="Lore">
  <div class="lore-page">

    <!-- Season Story -->
    <section class="lore-section season-section">
      <div class="lore-eyebrow">SEASON OF THE POWERLEVEL</div>
      <h1 class="lore-title">{season.name}</h1>
      <p class="lore-body">{season.lore}</p>
    </section>

    <!-- Guardian Bio -->
    <section class="lore-section bio-section">
      <div class="lore-eyebrow">GUARDIAN RECORD</div>
      <h2 class="lore-title">@castrojo</h2>
      <div class="bio-stats">
        <span class="bio-stat"><span class="bio-label">CLASS</span> {bio.class}</span>
        <span class="bio-stat"><span class="bio-label">SUBCLASS</span> {bio.subclass}</span>
        <span class="bio-stat"><span class="bio-label">TITLE</span> {bio.title}</span>
      </div>
      <p class="lore-body">{bio.background}</p>
      <div class="bio-spec">
        <span class="bio-label">SPECIALIZATION</span>
        <span class="spec-val">{bio.specialization}</span>
      </div>
      <blockquote class="lore-quote">"{bio.quote}"</blockquote>
    </section>

    <!-- Subclass Lore -->
    <section class="lore-section elements-section">
      <div class="lore-eyebrow">SUBCLASS DISCIPLINES</div>
      <h2 class="lore-title">The Five Elements</h2>
      <div class="elements-grid">
        {subclassElements.map(el => (
          <div class={`element-card ${el.element}`} style={`border-left-color: ${el.color}`}>
            <div class="element-header">
              <span class="element-icon">{el.icon}</span>
              <span class="element-name" style={`color: ${el.color}`}>{el.name}</span>
            </div>
            <p class="element-lore">{el.lore}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Lore Stream -->
    {streamEntries.length > 0 && (
      <section class="lore-section stream-section">
        <div class="lore-eyebrow">RECENTLY REVEALED</div>
        <h2 class="lore-title">Lore Stream</h2>
        <div class="stream-entries">
          {streamEntries.map(({ book, chapter }) => (
            <button
              class="stream-entry"
              data-book={book.id}
              data-chapter={chapter.id}
              style={`border-left-color: ${book.accent}`}
            >
              <div class="stream-meta">
                <span class="stream-book" style={`color: ${book.accent}`}>{book.icon} {book.title}</span>
                <span class="stream-classification">{chapter.classification}</span>
              </div>
              <div class="stream-title">{chapter.title}</div>
              <div class="stream-preview">{chapter.paragraphs[0].slice(0, 120)}…</div>
            </button>
          ))}
        </div>
      </section>
    )}

    <!-- Lore Archive -->
    <section class="lore-section archive-section">
      <div class="lore-eyebrow">LORE ARCHIVE · {resolvedBooks.reduce((n, b) => n + b.unlockedCount, 0)} ENTRIES UNLOCKED</div>
      <h2 class="lore-title">The Archive</h2>

      <!-- Book hero grid -->
      <div class="book-grid" id="book-grid">
        {resolvedBooks.map(book => (
          <button
            class="book-hero-card"
            data-book-id={book.id}
            style={`--book-start: ${book.color_start}; --book-end: ${book.color_end}; --book-accent: ${book.accent}`}
          >
            <div class="book-hero-bg" />
            <div class="book-hero-content">
              <div class="book-hero-icon">{book.icon}</div>
              <div class="book-hero-subtitle">{book.subtitle}</div>
              <div class="book-hero-title">{book.title}</div>
              <div class="book-hero-tagline">{book.tagline}</div>
              <div class="book-hero-progress">
                <div class="book-progress-bar">
                  <div
                    class="book-progress-fill"
                    style={`width: ${Math.round((book.unlockedCount / book.totalCount) * 100)}%; background: ${book.accent}`}
                  />
                </div>
                <span class="book-progress-label" style={`color: ${book.accent}`}>
                  {book.unlockedCount} / {book.totalCount} ENTRIES
                </span>
              </div>
            </div>
          </button>
        ))}
      </div>

      <!-- Reader panel (hidden until book selected) -->
      <div class="book-reader" id="book-reader" aria-hidden="true">
        <div class="reader-header">
          <button class="reader-close" id="reader-close" aria-label="Close reader">✕ CLOSE</button>
          <div class="reader-book-title" id="reader-book-title"></div>
        </div>
        <div class="reader-body">
          <nav class="reader-chapter-list" id="reader-chapter-list" aria-label="Chapters"></nav>
          <article class="reader-content" id="reader-content" aria-live="polite"></article>
        </div>
      </div>
    </section>

    <!-- Ghost Messages -->
    <section class="lore-section ghost-section">
      <div class="lore-eyebrow">GHOST TRANSMISSION LOG</div>
      <h2 class="lore-title">From Your Ghost</h2>
      <div class="ghost-messages">
        {ghostMessages.map((msg) => (
          <div class="ghost-msg">
            <span class="ghost-icon">👻</span>
            <p class="ghost-text">"{msg}"</p>
          </div>
        ))}
      </div>
    </section>

  </div>
</D2Layout>

<script define:vars={{ loreBooksData: resolvedBooks }}>
  const bookMap = Object.fromEntries(loreBooksData.map(b => [b.id, b]));

  const grid = document.getElementById('book-grid');
  const reader = document.getElementById('book-reader');
  const closeBtn = document.getElementById('reader-close');
  const readerTitle = document.getElementById('reader-book-title');
  const chapterList = document.getElementById('reader-chapter-list');
  const contentPane = document.getElementById('reader-content');

  function renderChapter(ch, book) {
    if (!contentPane) return;
    const accent = book.accent;
    let html = `<div class="rc-classification" style="color:${accent}">${ch.classification}</div>`;
    html += `<h3 class="rc-title">${ch.number}. ${ch.title}</h3>`;
    if (ch.date) html += `<div class="rc-date">${ch.date}</div>`;

    if (!ch.isUnlocked) {
      const hint = ch.unlock_after_sessions
        ? `Requires ${ch.unlock_after_sessions} sessions`
        : ch.unlock_triumph
        ? `Requires triumph: ${ch.unlock_triumph}`
        : 'Locked';
      html += `<div class="rc-locked">`;
      if (ch.teaser) html += `<p class="rc-teaser">${ch.teaser}</p>`;
      html += `<div class="rc-redacted"><span class="rc-lock">🔒</span><span>${hint}</span></div></div>`;
    } else {
      ch.paragraphs.forEach(p => { html += `<p class="rc-para">${p}</p>`; });
      if (ch.mantra) html += `<p class="rc-mantra">${ch.mantra}</p>`;
      if (ch.oaths) {
        html += `<div class="rc-oaths">` + ch.oaths.map(o => `<p class="rc-oath" style="border-left-color:${accent}">${o}</p>`).join('') + `</div>`;
      }
      if (ch.blockquote) html += `<blockquote class="rc-quote" style="border-left-color:${accent}">"${ch.blockquote}"</blockquote>`;
      if (ch.author) html += `<div class="rc-author">— ${ch.author}</div>`;
      if (ch.links) {
        html += `<div class="rc-links">` + ch.links.map(l =>
          `<a href="${l.url}" class="rc-link" target="_blank" rel="noopener" style="border-color:${accent}">
            <span class="rc-link-act" style="color:${accent}">${l.act}</span>
            <span class="rc-link-title">${l.title}</span>
            <span class="rc-link-cta">Open →</span>
          </a>`).join('') + `</div>`;
      }
    }
    contentPane.innerHTML = html;
    contentPane.scrollTop = 0;
  }

  function setActive(chapterId) {
    chapterList && chapterList.querySelectorAll('.cl-entry').forEach(el => {
      el.classList.toggle('cl-active', el.dataset.chapterId === chapterId);
    });
  }

  function openBook(bookId, targetChapterId) {
    const book = bookMap[bookId];
    if (!book || !reader || !readerTitle || !chapterList) return;

    readerTitle.textContent = `${book.icon}  ${book.title}`;
    readerTitle.style.color = book.accent;

    chapterList.innerHTML = book.chapters.map(ch => `
      <button class="cl-entry ${ch.isUnlocked ? '' : 'cl-locked'}" data-chapter-id="${ch.id}" data-book-id="${bookId}">
        <span class="cl-num" style="color:${book.accent}">${ch.number}</span>
        <span class="cl-title">${ch.title}</span>
        ${!ch.isUnlocked ? '<span class="cl-lock-icon">🔒</span>' : ''}
      </button>`).join('');

    reader.classList.add('reader-open');
    reader.removeAttribute('aria-hidden');
    if (grid) grid.style.display = 'none';

    const firstChapter = book.chapters.find(ch => targetChapterId ? ch.id === targetChapterId : ch.isUnlocked) || book.chapters[0];
    renderChapter(firstChapter, book);
    setActive(firstChapter.id);
  }

  // Direct listeners on each book card (more reliable than delegation)
  document.querySelectorAll('.book-hero-card[data-book-id]').forEach(card => {
    card.addEventListener('click', () => openBook(card.dataset.bookId));
  });

  // Chapter list — delegated from the container (populated dynamically)
  chapterList && chapterList.addEventListener('click', e => {
    const btn = e.target.closest('[data-chapter-id]');
    if (!btn) return;
    const book = bookMap[btn.dataset.bookId];
    const ch = book && book.chapters.find(c => c.id === btn.dataset.chapterId);
    if (ch) { renderChapter(ch, book); setActive(ch.id); }
  });

  closeBtn && closeBtn.addEventListener('click', () => {
    reader && reader.classList.remove('reader-open');
    reader && reader.setAttribute('aria-hidden', 'true');
    if (grid) grid.style.display = '';
  });

  document.querySelectorAll('.stream-entry[data-book]').forEach(btn => {
    btn.addEventListener('click', () => openBook(btn.dataset.book, btn.dataset.chapter));
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && reader && reader.classList.contains('reader-open')) {
      closeBtn && closeBtn.click();
    }
  });
</script>

<style>
.lore-page { max-width: 860px; margin: 0 auto; }
.lore-section { margin-bottom: 4rem; padding: 2rem; background: var(--d2-surface); border: 1px solid var(--d2-border); border-radius: 4px; }
.season-section { border-top: 2px solid var(--d2-exotic); background: linear-gradient(135deg, #0a0a0f 0%, #12121a 100%); }
.bio-section { border-top: 2px solid var(--d2-arc); }
.elements-section { background: transparent; border: none; padding: 0; }
.ghost-section { border-top: 2px solid var(--d2-void); }
.lore-eyebrow { font-size: 0.7rem; letter-spacing: 0.15em; color: var(--d2-text-dim); text-transform: uppercase; margin-bottom: 0.5rem; }
.lore-title { font-family: var(--font-lore); font-size: 2rem; color: var(--d2-exotic); margin-bottom: 1rem; }
.lore-body { color: var(--d2-text); line-height: 1.8; font-size: 1rem; }
.bio-stats { display: flex; gap: 2rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
.bio-stat { display: flex; flex-direction: column; gap: 0.25rem; }
.bio-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--d2-text-dim); }
.bio-spec { margin-top: 1rem; display: flex; gap: 1rem; align-items: center; }
.spec-val { color: var(--d2-arc); font-size: 0.85rem; }
.lore-quote { border-left: 2px solid var(--d2-exotic); margin: 1.5rem 0 0; padding: 0.5rem 1rem; color: var(--d2-text-dim); font-style: italic; font-size: 0.95rem; }
.elements-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1px; border: 1px solid var(--d2-border); border-radius: 4px; overflow: hidden; }
.element-card { background: var(--d2-surface); padding: 1.25rem; border-left: 3px solid; }
.element-card:hover { background: var(--d2-surface-2); }
.element-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.element-icon { font-size: 1.5rem; }
.element-name { font-family: var(--font-lore); font-size: 1rem; font-weight: 700; }
.element-lore { color: var(--d2-text-dim); font-size: 0.85rem; line-height: 1.6; margin: 0; }
.ghost-messages { display: flex; flex-direction: column; gap: 1rem; }
.ghost-msg { display: flex; gap: 1rem; align-items: flex-start; padding: 1rem; background: var(--d2-surface-2); border-radius: 4px; border: 1px solid var(--d2-border); }
.ghost-icon { font-size: 1.5rem; flex-shrink: 0; }
.ghost-text { color: var(--d2-text); font-style: italic; margin: 0; line-height: 1.6; }
.chronicle-section { border-top: 2px solid var(--d2-exotic); }
.chronicle-intro { font-style: italic; color: var(--d2-text-dim); margin-bottom: 2rem; }
.grimoire-cards { display: flex; flex-direction: column; gap: 1.5rem; }
.grimoire-card { background: var(--d2-surface-2); border: 1px solid var(--d2-border); border-radius: 2px; padding: 1.5rem; position: relative; }
.grimoire-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--d2-exotic) 0%, transparent 100%); }
.iron-lords-card::before { background: linear-gradient(90deg, #c8a84b 0%, transparent 100%); }
.grimoire-classification { font-size: 0.6rem; letter-spacing: 0.18em; color: var(--d2-text-dim); text-transform: uppercase; margin-bottom: 0.5rem; opacity: 0.6; }
.grimoire-chapter { font-family: var(--font-lore); font-size: 1.3rem; color: var(--d2-exotic); margin-bottom: 0.25rem; }
.grimoire-date { font-size: 0.75rem; color: var(--d2-text-dim); margin-bottom: 1rem; letter-spacing: 0.08em; }
.grimoire-text p { color: var(--d2-text); line-height: 1.8; font-size: 0.95rem; margin-bottom: 0.75rem; }
.grimoire-text p:last-child { margin-bottom: 0; }
.grimoire-text strong.guardian-name { color: var(--d2-solar); font-family: var(--font-lore); }
.grimoire-text code { background: var(--d2-surface); padding: 0.1em 0.4em; border-radius: 2px; font-size: 0.85em; color: var(--d2-arc); }
.grimoire-mantra { font-style: italic; color: var(--d2-exotic) !important; border-left: 2px solid var(--d2-exotic); padding-left: 1rem; }
.lore-link { color: var(--d2-solar); text-decoration: none; }
.lore-link:hover { text-decoration: underline; }
.chronicle-transmissions { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1.25rem; }
.transmission-link { display: grid; grid-template-columns: 3.5rem 1fr auto; align-items: center; gap: 1rem; padding: 0.75rem 1rem; background: var(--d2-surface); border: 1px solid var(--d2-border); border-radius: 2px; text-decoration: none; transition: border-color 0.15s, background 0.15s; }
.transmission-link:hover { border-color: var(--d2-exotic); background: var(--d2-surface-2); }
.transmission-act { font-size: 0.6rem; letter-spacing: 0.15em; color: var(--d2-exotic); text-transform: uppercase; font-weight: 700; }
.transmission-title { color: var(--d2-text); font-size: 0.9rem; }
.transmission-cta { font-size: 0.7rem; color: var(--d2-text-dim); letter-spacing: 0.08em; white-space: nowrap; }
.iron-oaths { margin: 1rem 0; display: flex; flex-direction: column; gap: 0.5rem; }
.oath { font-style: italic; color: var(--d2-text) !important; font-size: 1rem !important; padding-left: 1rem; border-left: 1px solid #c8a84b; margin-bottom: 0 !important; }
.exo-card::before { background: linear-gradient(90deg, #8a8aaa 0%, transparent 100%); }
.exo-transmission { border-left-color: #8a8aaa; color: #c8c8e0 !important; font-style: italic; font-size: 1.05rem; }
.exo-author { margin-top: 1.25rem; font-size: 0.75rem; letter-spacing: 0.12em; color: #6a6a88; text-align: right; font-family: var(--font-lore); text-transform: uppercase; }

/* ── Lore Stream ────────────────────────────────────────── */
.stream-section { border-top: 2px solid var(--d2-strand); }
.stream-entries { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem; }
.stream-entry { background: var(--d2-surface-2); border: 1px solid var(--d2-border); border-left: 3px solid; border-radius: 2px; padding: 1rem 1.25rem; text-align: left; cursor: pointer; transition: border-color 0.15s, background 0.15s; }
.stream-entry:hover { background: var(--d2-surface); }
.stream-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.35rem; }
.stream-book { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; }
.stream-classification { font-size: 0.6rem; letter-spacing: 0.14em; color: var(--d2-text-dim); text-transform: uppercase; opacity: 0.7; }
.stream-title { font-family: var(--font-lore); font-size: 1rem; color: var(--d2-text-bright); margin-bottom: 0.35rem; }
.stream-preview { font-size: 0.82rem; color: var(--d2-text-dim); line-height: 1.5; font-style: italic; }

/* ── Archive section ───────────────────────────────────── */
.archive-section { border-top: 2px solid var(--d2-exotic); }

/* ── Book hero grid ────────────────────────────────────── */
.book-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 2px; margin-top: 1.5rem; }
.book-hero-card { position: relative; min-height: 220px; border: 1px solid var(--d2-border); border-radius: 2px; overflow: hidden; cursor: pointer; text-align: left; transition: border-color 0.2s, transform 0.15s; background: none; padding: 0; }
.book-hero-card:hover { border-color: var(--book-accent); transform: translateY(-2px); }
.book-hero-card:hover .book-hero-bg { opacity: 0.9; }
.book-hero-bg { position: absolute; inset: 0; background: linear-gradient(135deg, var(--book-start) 0%, var(--book-end) 100%); transition: opacity 0.2s; }
.book-hero-content { position: relative; z-index: 1; padding: 1.5rem 1.25rem; height: 100%; display: flex; flex-direction: column; gap: 0.4rem; }
.book-hero-icon { font-size: 2rem; line-height: 1; margin-bottom: 0.25rem; }
.book-hero-subtitle { font-size: 0.6rem; letter-spacing: 0.18em; color: var(--book-accent); text-transform: uppercase; opacity: 0.8; }
.book-hero-title { font-family: var(--font-lore); font-size: 1.35rem; color: #fff; line-height: 1.2; }
.book-hero-tagline { font-size: 0.8rem; color: rgba(255,255,255,0.55); line-height: 1.5; flex: 1; font-style: italic; margin-top: 0.25rem; }
.book-hero-progress { margin-top: auto; padding-top: 0.75rem; }
.book-progress-bar { height: 2px; background: rgba(255,255,255,0.12); border-radius: 1px; margin-bottom: 0.4rem; }
.book-progress-fill { height: 100%; border-radius: 1px; transition: width 0.3s; }
.book-progress-label { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; }

/* ── Book reader ───────────────────────────────────────── */
.book-reader { display: none; margin-top: 1.5rem; border: 1px solid var(--d2-border); border-radius: 2px; overflow: hidden; }
.book-reader.reader-open { display: flex; flex-direction: column; }
.reader-header { display: flex; align-items: center; gap: 1rem; padding: 0.75rem 1.25rem; background: var(--d2-surface-2); border-bottom: 1px solid var(--d2-border); }
.reader-close { background: none; border: 1px solid var(--d2-border); color: var(--d2-text-dim); padding: 0.25rem 0.75rem; font-size: 0.7rem; letter-spacing: 0.1em; cursor: pointer; border-radius: 2px; transition: border-color 0.15s, color 0.15s; }
.reader-close:hover { border-color: var(--d2-text); color: var(--d2-text); }
.reader-book-title { font-family: var(--font-lore); font-size: 1.1rem; flex: 1; }
