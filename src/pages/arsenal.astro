---
import D2Layout from '../layouts/D2Layout.astro';
import rawData from '../../data/powerlevel-data.json';
import { levelTier } from '../lib/compute';

const weapons = rawData.weapons ?? {};

function levelColor(level: number): string {
  if (level >= 100) return 'var(--d2-masterwork)';
  if (level >= 90)  return '#a855f7';  // gilded — purple
  if (level >= 80)  return '#3fb6e6';  // ascendant — arc blue
  if (level >= 70)  return '#41c182';  // unbroken — strand green
  if (level >= 60)  return '#f2831a';  // forged — solar orange
  if (level >= 34)  return 'var(--pl-soft)';
  return 'var(--d2-text-dim)';
}

function milestoneTierColor(tier: string): string {
  switch (tier) {
    case 'Mastercrafted': return '#c9b037';
    case 'Adept':         return '#b4b4b4';
    case 'Pinnacle':      return '#e5c97e';
    case 'Transcendent':  return '#a855f7';
    default:              return '#888';
  }
}

const subclasses = [
  { element: 'arc',    icon: '⚡', name: 'VELOCITY',     super: 'Thundercrash / Fists of Havoc' },
  { element: 'solar',  icon: '🔥', name: 'COMMUNITY',    super: 'Hammer of Sol / Burning Maul' },
  { element: 'void',   icon: '🟣', name: 'MASTERY',      super: 'Sentinel Shield / Ward of Dawn' },
  { element: 'strand', icon: '🟢', name: 'DISTRIBUTION', super: 'Bladefury' },
  { element: 'stasis', icon: '🔵', name: 'STABILITY',    super: 'Glacial Quake' },
];

type WeaponEntry = { weapon: string; weapon_type: string; element: string; level: number; primary?: boolean; milestone_tier?: string };
const weaponEntries = Object.entries(weapons) as [string, WeaponEntry][];
---

<D2Layout title="Arsenal">
  <div class="arsenal">
    <h1>Arsenal</h1>
    <p class="page-sub">Every skill is a weapon. Every weapon has a level.</p>

    {subclasses.map(sc => {
      const scWeapons = weaponEntries.filter(([, w]) => w.element === sc.element);
      const avg = scWeapons.length
        ? Math.round(scWeapons.reduce((s, [, w]) => s + w.level, 0) / scWeapons.length)
        : 0;
      return (
        <section class={`subclass-section ${sc.element}`}>
          <div class="subclass-header">
            <span class="subclass-icon">{sc.icon}</span>
            <div>
              <h2 class="subclass-name">{sc.name}</h2>
              <p class="subclass-super">{sc.super}</p>
            </div>
            <div class="subclass-avg">
              <span class="avg-num">{avg}</span>
              <span class="avg-label">avg</span>
            </div>
          </div>
          <div class="weapon-grid">
            {scWeapons.map(([id, w]) => (
              <div class={`weapon-card${w.level === 100 ? ' masterwork-glow' : ''}`}>
                <div class="weapon-header">
                  <div>
                    <div class="weapon-name">{w.weapon}</div>
                    <div class="weapon-type">{w.weapon_type}</div>
                  </div>
                  {w.primary && <span class="primary-badge">★ PRIMARY</span>}
                </div>
                <div class="skill-id">{id}</div>
                <div class="level-bar">
                  <div class="level-bar-fill" style={`width: ${w.level}%; background: ${levelColor(w.level)}`}></div>
                </div>
                <div class="weapon-footer">
                  <span class="tier-name" style={`color: ${levelColor(w.level)}`}>{levelTier(w.level)}</span>
                  <div class="level-num-group">
                    {w.milestone_tier && (
                      <span
                        class="milestone-badge"
                        style={`background: ${milestoneTierColor(w.milestone_tier)}22; color: ${milestoneTierColor(w.milestone_tier)}; border: 1px solid ${milestoneTierColor(w.milestone_tier)}55`}
                      >{w.milestone_tier}</span>
                    )}
                    <span class="level-num">Lv. {w.level}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</D2Layout>

<style>
h1 { font-family: var(--font-lore); font-size: 2rem; color: var(--d2-exotic); margin-bottom: 0.5rem; }
.page-sub { color: var(--d2-text-dim); margin-bottom: 2rem; }
.subclass-section { margin-bottom: 3rem; }
.subclass-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.5rem;
  background: var(--d2-surface);
  border-radius: 4px 4px 0 0;
  border: 1px solid var(--d2-border);
  border-bottom: none;
}
.subclass-section.arc    .subclass-header { border-left: 3px solid var(--d2-arc); }
.subclass-section.solar  .subclass-header { border-left: 3px solid var(--d2-solar); }
.subclass-section.void   .subclass-header { border-left: 3px solid var(--d2-void); }
.subclass-section.strand .subclass-header { border-left: 3px solid var(--d2-strand); }
.subclass-section.stasis .subclass-header { border-left: 3px solid var(--d2-stasis); }
.subclass-icon { font-size: 2rem; }
.subclass-name { font-family: var(--font-lore); font-size: 1.25rem; color: var(--d2-text-bright); }
.subclass-super { font-size: 0.75rem; color: var(--d2-text-dim); }
.subclass-avg { margin-left: auto; text-align: right; }
.avg-num { font-size: 1.5rem; color: var(--d2-text-bright); font-family: var(--font-lore); }
.avg-label { display: block; font-size: 0.7rem; color: var(--d2-text-dim); text-transform: uppercase; }
.weapon-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1px;
  border: 1px solid var(--d2-border);
  border-radius: 0 0 4px 4px;
  overflow: hidden;
}
.weapon-card {
  background: var(--d2-surface);
  padding: 1rem;
  transition: background 0.2s;
}
.weapon-card:hover { background: var(--d2-surface-2); }
.weapon-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem; }
.weapon-name { font-size: 0.9rem; color: var(--d2-text-bright); font-weight: 700; }
.weapon-type { font-size: 0.7rem; color: var(--d2-text-dim); }
.primary-badge { font-size: 0.65rem; color: var(--d2-exotic); white-space: nowrap; }
.skill-id { font-size: 0.65rem; color: var(--d2-text-dim); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem; }
.level-bar { height: 3px; background: var(--d2-border); border-radius: 2px; margin-bottom: 0.5rem; }
.level-bar-fill { height: 100%; border-radius: 2px; transition: width 1s ease; }
.weapon-footer { display: flex; justify-content: space-between; align-items: center; }
.level-num-group { display: flex; align-items: center; gap: 0.35rem; }
.milestone-badge { font-size: 0.6rem; padding: 0.1rem 0.35rem; border-radius: 999px; font-weight: 700; letter-spacing: 0.04em; white-space: nowrap; }
.tier-name { font-size: 0.7rem; }
.level-num { font-size: 0.7rem; color: var(--d2-text-dim); }
</style>
